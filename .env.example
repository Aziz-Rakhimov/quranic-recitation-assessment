# Tilawa API Environment Variables
# Copy this file to .env and fill in real values for local development
# On cloud deployment, set these as environment variables in the dashboard

# API key that the frontend must send in X-API-Key header
# Generate a strong random key for production
TILAWA_API_KEY=your-secret-api-key-here

# Allowed origins for CORS (comma-separated)
# For local frontend development: http://localhost:3000,http://localhost:8081
# For production: your actual frontend domain
TILAWA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
